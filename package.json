{
  "name": "neon-pong-tiktok",
  "version": "2.0.0",
  "description": "Neon Pong × TikTok Live — Production",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop neon-pong",
    "pm2:logs": "pm2 logs neon-pong",
    "pm2:restart": "pm2 restart neon-pong",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "dependencies": {
    "tiktok-live-connector": "^2.0.9",
    "ws": "^8.16.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "pm2": "^5.3.1"
  },
  "build": {
    "appId": "com.neonpong.app",
    "productName": "Neon Pong",
    "copyright": "Copyright © 2025",
    "files": [
      "index.html",
      "server.js",
      "electron/**/*",
      ".env.example"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "category": "public.app-category.games",
      "darkModeSupport": true
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "publisherName": "Neon Pong"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "author": "You",
  "license": "MIT",
  "engines": { "node": ">=18.0.0" }
}
